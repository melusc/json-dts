{
	"author": {
		"name": "lusc",
		"url": "https://github.com/melusc"
	},
	"ava": {
		"files": [
			"test/**/*"
		],
		"typescript": {
			"compile": false,
			"extensions": [
				"ts"
			],
			"rewritePaths": {
				"test/": "dist/test/"
			}
		}
	},
	"exports": {
		".": "./dist/src/index.js"
	},
	"packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
	"description": "Convert json to typescript dts",
	"devDependencies": {
		"@ava/typescript": "^6.0.0",
		"@fast-check/ava": "^2.0.2",
		"@lusc/clean-package": "^3.0.0",
		"@lusc/eslint-config": "^8.2.0",
		"@lusc/tsconfig": "^7.2.0",
		"@types/node": "^24.10.1",
		"ava": "^6.4.1",
		"eslint": "^9.39.1",
		"prettier": "^3.7.4",
		"rimraf": "^6.1.2",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": "^20.19.1 || ^22.15.0 || ^24.6.0 || ^25.0.0"
	},
	"files": [
		"./dist/src"
	],
	"keywords": [
		"json",
		"types",
		"typescript",
		"declaration",
		"dts"
	],
	"license": "MIT",
	"name": "@lusc/json-dts",
	"repository": {
		"type": "git",
		"url": "https://github.com/melusc/json-dts"
	},
	"scripts": {
		"fmt": "prettier -w . && eslint --fix",
		"test": "pnpm build && ava",
		"build": "pnpm clean && tsc",
		"clean": "rimraf dist"
	},
	"type": "module",
	"version": "6.1.0",
	"dependencies": {
		"camelcase": "^8.0.0"
	}
}
