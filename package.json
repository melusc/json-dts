{
	"author": {
		"name": "lusc",
		"url": "https://github.com/melusc"
	},
	"ava": {
		"files": [
			"test/**/*"
		],
		"typescript": {
			"compile": false,
			"extensions": [
				"ts"
			],
			"rewritePaths": {
				"test/": "dist/test/"
			}
		}
	},
	"exports": {
		".": "./dist/src/index.js"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"description": "Convert json to typescript dts",
	"devDependencies": {
		"@ava/typescript": "^6.0.0",
		"@fast-check/ava": "^2.0.2",
		"@lusc/clean-package": "^3.0.0",
		"@lusc/eslint-config": "^9.0.0",
		"@lusc/tsconfig": "^7.2.0",
		"@types/node": "^24.12.0",
		"ava": "^7.0.0",
		"eslint": "^10.0.3",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": "^22.15.0 || ^24.6.0 || ^25.0.0"
	},
	"files": [
		"./dist/src"
	],
	"keywords": [
		"json",
		"types",
		"typescript",
		"declaration",
		"dts"
	],
	"license": "MIT",
	"name": "@lusc/json-dts",
	"repository": {
		"type": "git",
		"url": "https://github.com/melusc/json-dts"
	},
	"scripts": {
		"fmt": "prettier -w . && eslint --fix",
		"test": "pnpm build && ava",
		"build": "pnpm clean && tsc",
		"clean": "rimraf dist"
	},
	"type": "module",
	"version": "7.0.0",
	"dependencies": {
		"camelcase": "^9.0.0"
	}
}
