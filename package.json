{
	"author": {
		"name": "lusc",
		"url": "https://github.com/melusc"
	},
	"ava": {
		"files": [
			"test/**/*"
		],
		"typescript": {
			"compile": false,
			"extensions": [
				"ts"
			],
			"rewritePaths": {
				"test/": "dist/test/"
			}
		}
	},
	"exports": {
		".": "./dist/src/index.js"
	},
	"packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
	"description": "Convert json to typescript dts",
	"devDependencies": {
		"@ava/typescript": "^6.0.0",
		"@fast-check/ava": "^2.0.2",
		"@lusc/clean-package": "^3.0.0",
		"@lusc/eslint-config": "^8.6.0",
		"@lusc/tsconfig": "^7.2.0",
		"@types/node": "^24.10.10",
		"ava": "^6.4.1",
		"eslint": "^9.39.2",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.2",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": "^22.15.0 || ^24.6.0 || ^25.0.0"
	},
	"files": [
		"./dist/src"
	],
	"keywords": [
		"json",
		"types",
		"typescript",
		"declaration",
		"dts"
	],
	"license": "MIT",
	"name": "@lusc/json-dts",
	"repository": {
		"type": "git",
		"url": "https://github.com/melusc/json-dts"
	},
	"scripts": {
		"fmt": "prettier -w . && eslint --fix",
		"test": "pnpm build && ava",
		"build": "pnpm clean && tsc",
		"clean": "rimraf dist"
	},
	"type": "module",
	"version": "7.0.0",
	"dependencies": {
		"camelcase": "^9.0.0"
	}
}
