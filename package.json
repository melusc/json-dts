{
	"author": {
		"name": "lusc",
		"url": "https://github.com/melusc"
	},
	"ava": {
		"files": [
			"test/**/*"
		],
		"typescript": {
			"compile": false,
			"extensions": [
				"ts"
			],
			"rewritePaths": {
				"test/": "dist/test/"
			}
		}
	},
	"exports": {
		".": "./dist/src/index.js"
	},
	"packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef",
	"description": "Convert json to typescript dts",
	"devDependencies": {
		"@ava/typescript": "^6.0.0",
		"@fast-check/ava": "^2.0.2",
		"@lusc/clean-package": "^2.2.0",
		"@lusc/eslint-config": "^8.0.1",
		"@lusc/tsconfig": "^7.1.0",
		"@types/node": "^24.5.2",
		"ava": "^6.4.1",
		"eslint": "^9.36.0",
		"prettier": "^3.6.2",
		"rimraf": "^6.0.1",
		"typescript": "^5.9.2"
	},
	"engines": {
		"node": "^20.19.1 || ^22.15.0 || ^24.6.0"
	},
	"files": [
		"./dist/src"
	],
	"keywords": [
		"json",
		"types",
		"typescript",
		"declaration",
		"dts"
	],
	"license": "MIT",
	"name": "@lusc/json-dts",
	"repository": {
		"type": "git",
		"url": "https://github.com/melusc/json-dts"
	},
	"scripts": {
		"fmt": "prettier -w . && eslint --fix",
		"test": "pnpm build && ava",
		"build": "pnpm clean && tsc",
		"clean": "rimraf dist"
	},
	"type": "module",
	"version": "6.0.0",
	"dependencies": {
		"camelcase": "^8.0.0"
	}
}
